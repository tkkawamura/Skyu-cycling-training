# Copy these values into Streamlit Community Cloud "Secrets".
# Do not commit a real secrets.toml file with real keys.

INTERVALS_API_KEY = "replace_with_your_intervals_api_key"
INTERVALS_BASE_URL = "https://intervals.icu"

# Simple access guard for the public Streamlit URL.
# Leave empty only for a private/local test.
APP_PASSWORD = "replace_with_a_private_password"

ATHLETE_CRITICAL_POWER_W = 250
ATHLETE_BODY_MASS_KG = 63
ATHLETE_MAX_HEART_RATE_BPM = 178
ATHLETE_W_PRIME_KJ = 0

LOOKBACK_DAYS = 21
FIT_DOWNLOAD = true
